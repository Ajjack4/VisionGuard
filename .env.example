# VisionGuard AI — Configuration Template
# Copy this file to .env and edit values as needed.

# ── Video Source ────────────────────────────────────────────────────────────
# Use "0" for built-in webcam
# Use "1", "2" etc for external webcam
# Use "http://YOUR_PHONE_IP:8080/video" for Android IP Webcam app
# Use "rtsp://user:pass@IP:554/stream" for IP cameras
# Use a file path like "video.mp4" for offline testing
SOURCE=0

# ── Model Settings ──────────────────────────────────────────────────────────
# YOLO model: yolov8n.pt (fast), yolov8s.pt, yolov8m.pt (more accurate)
YOLO_MODEL=yolov8n.pt
YOLO_CONF=0.45

# Optional: path to a fine-tuned violence classifier state dict (.pth)
# Leave blank to use the default pretrained backbone (random/Kinetics init)
# MODEL_PATH=my_violence_model.pth

# ── Gate Settings ───────────────────────────────────────────────────────────
# GATE_ALPHA: proximity multiplier — two people are "close" if their
# centroid distance < GATE_ALPHA * max(diagonal_1, diagonal_2)
GATE_ALPHA=2.5
GATE_MIN_PEOPLE=2

# ── Classifier Settings ─────────────────────────────────────────────────────
CLASSIFIER_THRESHOLD=0.65
# Number of consecutive positive clips before an alert fires
PERSISTENCE_COUNT=2
# Temporal buffer: number of frames per clip
BUFFER_SIZE=16
# Spatial resize for classifier input
CLIP_SIZE=112

# ── Alert Settings ───────────────────────────────────────────────────────────
ALERT_COOLDOWN=60
SAVE_CLIPS=true
SAVE_SNAPSHOTS=true

# ── Tracking ────────────────────────────────────────────────────────────────
TRACK_MAX_AGE=30

# ── Display ─────────────────────────────────────────────────────────────────
DISPLAY=true

# ── API ─────────────────────────────────────────────────────────────────────
API_PORT=8000

# ── Performance ─────────────────────────────────────────────────────────────
FPS_LIMIT=15
