# VisionGuard AI — Configuration Template
# Copy this file to .env and edit values as needed.

# ── Video Source ─────────────────────────────────────────────────────────────
# Set SOURCE_TYPE to one of:  webcam | file | youtube
# Then fill in the matching param below.
# Leave SOURCE_TYPE blank (or remove it) to use the legacy SOURCE= value.

SOURCE_TYPE=webcam

# Laptop / USB webcam  (SOURCE_TYPE=webcam)
WEBCAM_INDEX=0

# Local video file  (SOURCE_TYPE=file)
# VIDEO_FILE=C:/path/to/video.mp4

# YouTube live stream or video  (SOURCE_TYPE=youtube)
# YOUTUBE_URL=https://www.youtube.com/watch?v=XXXXXXXXXX
# YOUTUBE_QUALITY=best[height<=720]   # other options: best[height<=1080] / best / worst

# ── Legacy single-value override (used when SOURCE_TYPE is blank) ────────────
# SOURCE=0

# ── Model Settings ──────────────────────────────────────────────────────────
# YOLO model: yolov8n.pt (fast), yolov8s.pt, yolov8m.pt (more accurate)
YOLO_MODEL=yolov8n.pt
YOLO_CONF=0.45

# Optional: path to a fine-tuned violence classifier state dict (.pth / .pt)
# Leave blank to use the default pretrained backbone (Kinetics zero-shot)
# MODEL_PATH=models/slowfast_violence.pt

# MODEL_TYPE selects the classifier backbone:
#   kinetics_heuristic  — zero-shot, no training needed (default)
#   r3d18               — fine-tuned R3D-18 binary head
#   x3d_xs / x3d_s / x3d_m / slowfast_r50  — torch.hub zero-shot variants
#   slowfast_violence   — fine-tuned SlowFast from train_slowfast.ipynb
#                         (also set BUFFER_SIZE=32 and MODEL_PATH above)
# MODEL_TYPE=kinetics_heuristic

# ── Gate Settings ───────────────────────────────────────────────────────────
# GATE_ALPHA: proximity multiplier — two people are "close" if their
# centroid distance < GATE_ALPHA * max(diagonal_1, diagonal_2)
GATE_ALPHA=2.5
GATE_MIN_PEOPLE=2

# ── Classifier Settings ─────────────────────────────────────────────────────
CLASSIFIER_THRESHOLD=0.65
# Number of consecutive positive clips before an alert fires
PERSISTENCE_COUNT=2
# Temporal buffer: number of frames per clip
BUFFER_SIZE=16
# Spatial resize for classifier input
CLIP_SIZE=112

# ── Alert Settings ───────────────────────────────────────────────────────────
ALERT_COOLDOWN=60
SAVE_CLIPS=true
SAVE_SNAPSHOTS=true

# ── Tracking ────────────────────────────────────────────────────────────────
TRACK_MAX_AGE=30

# ── Display ─────────────────────────────────────────────────────────────────
DISPLAY=true

# ── API ─────────────────────────────────────────────────────────────────────
API_PORT=8000

# ── Performance ─────────────────────────────────────────────────────────────
FPS_LIMIT=15
